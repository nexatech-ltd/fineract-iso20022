# ── Database ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=iso20022_adapter
DB_USERNAME=iso20022
DB_PASSWORD=CHANGE_ME
DB_USE_SSL=false
MYSQL_ROOT_PASSWORD=CHANGE_ME

# ── Redis / DragonflyDB ──────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL_ENABLED=false

# ── Kafka ─────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# For SSL: KAFKA_SECURITY_PROTOCOL=SSL
# KAFKA_SSL_TRUSTSTORE=/path/to/truststore.jks
# KAFKA_SSL_TRUSTSTORE_PASSWORD=CHANGE_ME
# KAFKA_SSL_KEYSTORE=/path/to/keystore.jks
# KAFKA_SSL_KEYSTORE_PASSWORD=CHANGE_ME

# ── Fineract API ─────────────────────────────────
FINERACT_API_URL=http://localhost:8443/fineract-provider/api/v1
FINERACT_API_USERNAME=mifos
FINERACT_API_PASSWORD=CHANGE_ME
FINERACT_TENANT_ID=default
FINERACT_MYSQL_ROOT_PASSWORD=CHANGE_ME

# ── Security ─────────────────────────────────────
# AES-256 key (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=
RATE_LIMIT_RPS=50
CORS_ALLOWED_ORIGINS=
